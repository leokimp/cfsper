{
  "id": "community.tmdb.discover.plus",
  "name": "Jim",
  "description": "Create custom movie and TV catalogs with powerful TMDB filters",
  "version": "1.0.0",
  "logo": "https://tmdb-discover-plus.elfhosted.com/logo.png",
  "idPrefixes": [
    "tmdb:",
    "tt"
  ],
  "resources": [
    "catalog",
    "meta"
  ],
  "types": [
    "movie",
    "series"
  ],
  "catalogs": [
    {
      "id": "tmdb-aa40d6c4-e193-4421-b9b8-658c5217e3fa",
      "type": "movie",
      "name": "Newly Released",
      "pageSize": 100,
      "extra": [
        {
          "name": "skip"
        },
        {
          "name": "genre",
          "options": [
            "Action",
            "Adventure",
            "Animation",
            "Comedy",
            "Crime",
            "Documentary",
            "Drama",
            "Mystery",
            "Romance",
            "Science Fiction",
            "Thriller",
            "TV Movie"
          ],
          "optionsLimit": 1,
          "isRequired": false
        }
      ]
    },
    {
      "id": "imdb-search-movie",
      "type": "movie",
      "name": "IMDb Search",
      "extra": [
        {
          "name": "search",
          "isRequired": true
        },
        {
          "name": "skip"
        }
      ]
    },
    {
      "id": "imdb-search-series",
      "type": "series",
      "name": "IMDb Search",
      "extra": [
        {
          "name": "search",
          "isRequired": true
        },
        {
          "name": "skip"
        }
      ]
    }
  ],
  "behaviorHints": {
    "configurable": true,
    "configurationRequired": false,
    "newEpisodeNotifications": true
  }
}
